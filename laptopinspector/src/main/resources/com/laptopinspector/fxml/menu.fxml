<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.laptopinspector.controller.MenuController"
      styleClass="root-pane"
      prefWidth="860"
      prefHeight="580">

    <!-- ========================================== -->
    <!-- SIDEBAR -->
    <!-- ========================================== -->

    <VBox styleClass="sidebar"
          prefWidth="220"
          spacing="0">

        <!-- Logo -->
        <VBox styleClass="logo-box"
              spacing="3">

            <Label text="Laptop Inspector"
                   styleClass="logo-title"/>

            <Label text="v1.0.0"
                   styleClass="logo-sub"/>

        </VBox>

        <!-- Navigation -->

        <Button text="  Dashboard"
                styleClass="nav-item active"
                prefWidth="220"
                prefHeight="42"/>

        <Button text="  Inspeksi Baru"
                styleClass="nav-item"
                prefWidth="220"
                prefHeight="42"/>

        <Button text="  Recent History"
                styleClass="nav-item"
                prefWidth="220"
                prefHeight="42"
                onAction="#onQuickHistoryClicked"/>

    </VBox>

    <!-- ========================================== -->
    <!-- MAIN CONTENT -->
    <!-- ========================================== -->

    <VBox VBox.vgrow="ALWAYS"
          HBox.hgrow="ALWAYS"
          spacing="0">

        <!-- ====================================== -->
        <!-- TOP BAR -->
        <!-- ====================================== -->

        <HBox styleClass="top-bar"
              alignment="CENTER_RIGHT"
              prefHeight="48">

            <Button fx:id="btnToggleTheme"
                    text="☀ Light Mode"
                    styleClass="btn-toggle"
                    onAction="#onToggleTheme"/>

        </HBox>

        <!-- ====================================== -->
        <!-- CONTENT -->
        <!-- ====================================== -->

        <VBox spacing="20"
              style="-fx-padding: 28;"
              VBox.vgrow="ALWAYS">

            <!-- Header -->

            <VBox spacing="4">

                <Label text="Pilih Mode Inspeksi"
                       styleClass="page-title"/>

                <Label text="Catat kondisi hardware sebelum atau sesudah peminjaman"
                       styleClass="page-subtitle"/>

            </VBox>

            <!-- Inspection Cards -->

            <HBox spacing="16">

                <!-- BEFORE -->

                <VBox styleClass="card-before"
                      spacing="14"
                      prefWidth="280"
                      HBox.hgrow="ALWAYS"
                      onMouseClicked="#onBeforeClicked">

                    <!-- Icon -->

                    <VBox alignment="CENTER"
                          style="-fx-background-color: -app-accent-bg;
                                 -fx-background-radius: 8;
                                 -fx-padding: 10;
                                 -fx-pref-width: 40;
                                 -fx-pref-height: 40;">

                        <Label text="◷"
                               style="-fx-text-fill: -app-accent;
                                      -fx-font-size: 18px;"/>

                    </VBox>

                    <!-- Title -->

                    <Label text="Inspeksi Before"
                           styleClass="card-title"/>

                    <!-- Description -->

                    <Label text="Catat kondisi awal perangkat sebelum dipinjam atau digunakan."
                           styleClass="card-desc"
                           wrapText="true"/>

                    <!-- Badge -->

                    <Label text="Kondisi Awal"
                           styleClass="badge-blue"/>

                    <!-- Button -->

                    <Button text="Mulai Before →"
                            styleClass="btn-primary"
                            prefHeight="38"
                            onAction="#onBeforeClicked"/>

                </VBox>

                <!-- AFTER -->

                <VBox styleClass="card-after"
                      spacing="14"
                      prefWidth="280"
                      HBox.hgrow="ALWAYS"
                      onMouseClicked="#onAfterClicked">

                    <!-- Icon -->

                    <VBox alignment="CENTER"
                          style="-fx-background-color: -app-success-bg;
                                 -fx-background-radius: 8;
                                 -fx-padding: 10;
                                 -fx-pref-width: 40;
                                 -fx-pref-height: 40;">

                        <Label text="✓"
                               style="-fx-text-fill: -app-success;
                                      -fx-font-size: 18px;"/>

                    </VBox>

                    <!-- Title -->

                    <Label text="Inspeksi After"
                           styleClass="card-title"/>

                    <!-- Description -->

                    <Label text="Catat kondisi akhir perangkat setelah pengembalian atau penggunaan."
                           styleClass="card-desc"
                           wrapText="true"/>

                    <!-- Badge -->

                    <Label text="Kondisi Akhir"
                           styleClass="badge-green"/>

                    <!-- Button -->

                    <Button text="Mulai After →"
                            prefHeight="38"
                            onAction="#onAfterClicked"
                            style="-fx-background-color: -app-success;
                                   -fx-text-fill: white;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 9 20;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>

                </VBox>

            </HBox>

            <!-- Spacer -->

            <VBox VBox.vgrow="ALWAYS"/>

            <!-- Footer Info -->

            <Label text="Data inspeksi akan dikirim ke server setelah mengisi Formulir Peminjaman Laptop."
                   styleClass="version-text"/>

        </VBox>

    </VBox>

</HBox>